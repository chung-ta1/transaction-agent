{
  "$schema": "node_modules/@openapitools/openapi-generator-cli/config.schema.json",
  "spaces": 2,
  "generator-cli": {
    "version": "7.12.0",
    "generators": {
      "arrakis": {
        "generatorName": "typescript-axios",
        "inputSpec": "https://arrakis.stagerealbrokerage.com/v3/api-docs/arrakis-public",
        "output": "./src/openapi/arrakis",
        "typeMappings": { "set": "Array", "object": "any" },
        "additionalProperties": { "withoutPrefixEnums": false, "stringEnums": true },
        "skipValidateSpec": true
      },
      "keymaker": {
        "generatorName": "typescript-axios",
        "inputSpec": "https://keymaker.stagerealbrokerage.com/v3/api-docs/keymaker-public",
        "output": "./src/openapi/keymaker",
        "typeMappings": { "set": "Array", "object": "any" },
        "additionalProperties": { "withoutPrefixEnums": false, "stringEnums": true },
        "skipValidateSpec": true
      },
      "yenta": {
        "generatorName": "typescript-axios",
        "inputSpec": "https://yenta.stagerealbrokerage.com/v3/api-docs/yenta-public",
        "output": "./src/openapi/yenta",
        "typeMappings": { "set": "Array", "object": "any" },
        "additionalProperties": { "withoutPrefixEnums": false, "stringEnums": true },
        "skipValidateSpec": true
      }
    }
  }
}
